# Copy this file to .env and fill in real values. NEVER commit .env.
# Only needed if you use the --email digest flag.

# Your Gmail address (the sender account)
GMAIL_ADDRESS=your_gmail_address_here

# A Google App Password (NOT your normal password).
# Generate one at https://myaccount.google.com/apppasswords
# (requires 2-Step Verification enabled on the account)
GMAIL_APP_PASSWORD=your_16_char_app_password_here

# Where to send the digest. Leave blank to send to GMAIL_ADDRESS itself.
EMAIL_RECIPIENT=

# --- AI mode (entirely optional) ---------------------------------------
# The app is complete without any of this. Set AI_PROVIDER to turn on the AI
# explanations; leave it unset (or "none") to stay in Standard mode.
#
# Choose ONE provider:
#
#   claude    — Anthropic API. Highest quality; sends job text and resume
#               skills to Anthropic. Needs ANTHROPIC_API_KEY.
#   ollama    — a local model via Ollama. Nothing leaves your machine. No key.
#   lmstudio  — a local model via LM Studio. Nothing leaves your machine.
#   openai    — OpenAI API. Needs OPENAI_API_KEY (or AI_API_KEY).
#
# AI_PROVIDER=claude
# ANTHROPIC_API_KEY=sk-ant-...
# AI_MODEL=claude-opus-4-8
#
# Local, private example (nothing leaves your PC):
# AI_PROVIDER=ollama
# AI_BASE_URL=http://localhost:11434/v1
# AI_MODEL=llama3.1
