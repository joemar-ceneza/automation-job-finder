# Copy this file to .env and fill in real values. NEVER commit .env.
# Only needed if you use the --email digest flag.

# Your Gmail address (the sender account)
GMAIL_ADDRESS=your_gmail_address_here

# A Google App Password (NOT your normal password).
# Generate one at https://myaccount.google.com/apppasswords
# (requires 2-Step Verification enabled on the account)
GMAIL_APP_PASSWORD=your_16_char_app_password_here

# Where to send the digest. Leave blank to send to GMAIL_ADDRESS itself.
EMAIL_RECIPIENT=
